<?xml version="1.0" encoding="utf-8"?>
<plasterManifest schemaVersion="1.1" templateType="project"
                 name="OMG.PSUtilities"
                 author="Your Name"
                 description="Scaffolds a PowerShell module project with README, .psd1, .psm1">
